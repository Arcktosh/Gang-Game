{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@drugdeal/db": [
        "../../packages/db/src"
      ],
      "@drugdeal/game": [
        "../../packages/game/src"
      ],
      "@drugdeal/validators": [
        "../../packages/validators/src"
      ],
      "@drugdeal/ui": [
        "../../packages/ui/src"
      ],
      "@drugdeal/observability": [
        "../../packages/observability/src"
      ]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
