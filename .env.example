DATABASE_URL="postgres://postgres:postgres@localhost:5432/drugdeal_game"
REDIS_URL="redis://localhost:6379"
RATE_LIMIT_REDIS_URL="redis://localhost:6379"
RATE_LIMIT_REDIS_PREFIX="drugdeal:rate-limit:"
RATE_LIMIT_REDIS_REQUIRED=false

# Container images. Defaults use AWS Public ECR mirrors of the official Docker images
# to avoid Docker Hub pull failures/rate limits. Override to docker.io/library/... if preferred.
POSTGRES_IMAGE=public.ecr.aws/docker/library/postgres:16-alpine
REDIS_IMAGE=public.ecr.aws/docker/library/redis:7-alpine
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=drugdeal_game
POSTGRES_PORT=5432
REDIS_PORT=6379
NEXT_PUBLIC_APP_NAME="DrugDeal Game"
AUTH_SECRET="replace-with-at-least-16-characters"

DB_POOL_SIZE="10"
# Public canonical application URL used for same-origin security checks.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side canonical application origin. Set this to the production HTTPS origin.
APP_ORIGIN=http://localhost:3000

# Optional comma-separated extra trusted origins for reverse proxies, preview URLs, or admin tooling.
TRUSTED_ORIGINS=

# Worker maintenance cleanup tuning.
MAINTENANCE_TICK_MS=900000
NOTIFICATION_DIGEST_RETENTION_DAYS=30
ACTION_LOCK_RETENTION_MINUTES=60
# Set to 0 to disable automatic message expiry. Defaults to 365 days.
MESSAGE_RETENTION_DAYS=365

# Worker retry/dead-letter tuning.
WORKER_TICK_MAX_ATTEMPTS=3
WORKER_TICK_RETRY_BASE_MS=1000
WORKER_TICK_RETRY_MAX_MS=30000
WORKER_DEAD_LETTER_DISABLED=false

# Operational anomaly detection. Tune thresholds per season/economy size.
ANOMALY_SCAN_TICK_MS=1800000
ANOMALY_SCAN_WINDOW_HOURS=24
ANOMALY_HIGH_NET_WORTH=1000000
ANOMALY_TRANSACTION_VOLUME=250000
ANOMALY_TRANSACTION_COUNT=50
ANOMALY_INVENTORY_QUANTITY=5000
ANOMALY_SESSION_IP_COUNT=6

# Optional vendor-neutral observability shipping. Events always remain structured JSON on stdout.
# Set one or both endpoints to ship sanitized events and critical alerts over HTTP.
OBSERVABILITY_HTTP_ENDPOINT=
OBSERVABILITY_ALERT_ENDPOINT=
OBSERVABILITY_API_KEY=
OBSERVABILITY_TIMEOUT_MS=2000
APP_RELEASE=

# Limit Next.js production build parallelism on shared/CI hosts.
NEXT_BUILD_CPUS=4
