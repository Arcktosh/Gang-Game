{
  "name": "@drugdeal/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/*.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:push": "drizzle-kit push",
    "db:ensure": "tsx scripts/ensure-database.ts",
    "db:setup": "pnpm db:ensure && pnpm db:apply:all",
    "db:apply:all": "tsx scripts/apply-migrations.ts",
    "db:apply:file": "tsx scripts/run-sql-file.ts",
    "db:prepare:mvp-proof": "tsx scripts/prepare-mvp-proof-database.ts"
  },
  "dependencies": {
    "@drugdeal/game": "workspace:*",
    "drizzle-orm": "latest",
    "postgres": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "drizzle-kit": "latest",
    "tsx": "^4.20.6",
    "typescript": "6.0.2"
  }
}
